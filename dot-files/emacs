(use-package ivy ;; completion framework
  :ensure t
  :config
  (setopt ivy-use-virtual-buffers t)
  (setopt ivy-use-selectable-prompt t)
  (setopt enable-recursive-minibuffers t)
  (setopt search-default-mode #'char-fold-to-regexp)
  (defun my/counsel-smart-find-file ()
    "Conditionally call project-aware find-file commands."
    (interactive)
    (cond
     ;; 1. Check if inside a Projectile project
     ((and (fboundp 'projectile-project-p) 
           (projectile-project-p))
      (counsel-projectile-find-file))
     
     ;; 2. Check if inside a Git repo (using built-in VC)
     ((and (fboundp 'vc-root-dir) 
           (vc-root-dir))
      (counsel-git))
     
     ;; 3. Fallback to standard directory navigation
     (t
      (counsel-find-file))))
  (defun my/counsel-smart-search ()
    "Search text: projectile-rg if in project, git-grep if in repo, else counsel-rg."
    (interactive)
    (cond
     ;; 1. Projectile Search (highly recommended for project-wide rg)
     ((and (fboundp 'projectile-project-p) 
           (projectile-project-p))
      (counsel-projectile-rg))
     
     ;; 2. Git Search (if in a git repo but not a projectile project)
     ((and (fboundp 'vc-root-dir) 
           (vc-root-dir))
      (counsel-git-grep))
     
     ;; 3. Fallback (standard ripgrep in the current directory)
     (t
      (counsel-rg))))

  :bind
  ("C-s" . 'swiper-isearch)
  ("M-x" . 'counsel-M-x)					;
  ("s-x" . 'repeat-complex-command)
  ("s-p" . 'my/counsel-smart-find-file) ;; same as VSCode, when I change editors avoid making mistakes
  ("s-P" . 'counsel-M-x)
  ("C-x C-f" . 'my/counsel-smart-find-file)
  ("C-x M-f" . 'counsel-recentf)
  ("M-y" . 'counsel-yank-pop)
  ("<f1> f" . 'counsel-describe-function)
  ("<f1> v" . 'counsel-describe-variable)
  ("<f1> o" . 'counsel-describe-symbol)
  ("<f1> l" . 'counsel-find-library)
  ("<f2> i" . 'counsel-info-lookup-symbol)
  ("<f2> u" . 'counsel-unicode-char)
  ("<f2> j" . 'counsel-set-variable)
  ("C-x b" . 'ivy-switch-buffer)
  ("C-c v" . 'ivy-push-view)
  ("C-c V" . 'ivy-pop-view)
  ;; system tools
  ("C-c c" . 'counsel-compile)
  ("C-c g" . 'counsel-git)
  ("C-c j" . 'counsel-git-grep)
  ("C-c L" . 'counsel-git-log)
  ("C-c k" . 'my/counsel-smart-search)
  ("C-c J" . 'counsel-file-jump)
  (:map minibuffer-local-map ("C-r" . 'counsel-minibuffer-history))
  :commands ivy-mode)

